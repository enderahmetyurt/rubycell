<% content_for :title, "Create account — RubyCell" %>

<div class="max-w-sm mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Create account</h1>

  <%= form_with model: @user, url: registrations_path, class: "bg-white border border-gray-200 rounded-xl p-6 space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-md px-3 py-2 text-sm">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
          placeholder: "you@example.com",
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ruby-500" %>
    </div>
    <div>
      <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password, required: true, autocomplete: "new-password", minlength: 12,
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ruby-500" %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ruby-500" %>
    </div>
    <%= f.submit "Create account", class: "w-full bg-ruby-600 text-white py-2 rounded-md text-sm font-medium hover:bg-ruby-700 cursor-pointer" %>
    <div class="text-center text-sm text-gray-500">
      Already have an account?
      <%= link_to "Sign in", new_session_path, class: "text-ruby-600 hover:underline" %>
    </div>
  <% end %>
</div>
