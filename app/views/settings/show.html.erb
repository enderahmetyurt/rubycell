<% content_for :title, "Settings — RubyCell" %>

<div class="max-w-lg">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Settings</h1>

  <%= form_with model: @user, url: settings_path, method: :patch, class: "space-y-6 bg-white border border-gray-200 rounded-xl p-6" do |f| %>
    <div>
      <h2 class="text-sm font-semibold text-gray-900 mb-1">Account</h2>
      <div class="flex items-center gap-2">
        <p class="text-sm text-gray-600"><%= @user.email_address %></p>
        <% if @user.confirmed? %>
          <span title="Email verified">✅</span>
        <% end %>
      </div>
      <% unless @user.confirmed? %>
        <div class="mt-2 flex items-center justify-between gap-3 bg-yellow-50 border border-yellow-300 rounded-md px-3 py-2">
          <span class="text-yellow-800 text-xs font-medium">Email not verified</span>
          <%= link_to "Verify email", resend_confirmation_settings_path,
              data: { turbo_method: :post },
              class: "text-xs bg-yellow-400 hover:bg-yellow-500 text-yellow-900 font-semibold px-3 py-1 rounded cursor-pointer transition-colors" %>
        </div>
      <% end %>
      <p class="text-xs text-gray-500 mt-1">
        Plan: <span class="font-medium"><%= @user.paid_active? ? "Paid (expires #{@user.plan_expires_at&.strftime("%b %d, %Y")})" : "Free" %></span>
      </p>
    </div>

    <div class="border-t border-gray-100 pt-6">
      <%= f.label :language, "Language preference", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :language, [["Both (TR + EN)", "lang_both"], ["Turkish", "lang_tr"], ["English", "lang_en"]],
          { selected: @user.language },
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ruby-500" %>
      <p class="text-xs text-gray-500 mt-1">Affects which summaries are shown and which digest you receive.</p>
    </div>

    <div>
      <%= f.label :frequency, "Digest frequency", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.select :frequency, [["None (no emails)", "unsubscribed"], ["Daily", "daily"], ["Weekly (Mondays)", "weekly"]],
          { selected: @user.frequency },
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-ruby-500" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Save settings", class: "bg-ruby-600 text-white px-5 py-2 rounded-md text-sm font-medium hover:bg-ruby-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
