<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "RubyCell — Ruby News Digest" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="RubyCell">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-sans antialiased text-gray-900">
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-14 items-center">
          <a href="<%= root_path %>" class="text-lg font-bold text-ruby-600 tracking-tight">
            💎 RubyCell
          </a>
          <div class="flex items-center gap-4 text-sm">
            <% if authenticated? %>
              <%= link_to "Dashboard", dashboard_path, class: "text-gray-600 hover:text-gray-900" %>
              <%= link_to "Settings", settings_path, class: "text-gray-600 hover:text-gray-900" %>
              <% unless Current.user.paid_active? %>
                <%= link_to "Upgrade", upgrade_path, class: "bg-ruby-600 text-white px-3 py-1.5 rounded-md hover:bg-ruby-700" %>
              <% end %>
              <%= button_to "Sign out", session_path, method: :delete, class: "text-gray-500 hover:text-gray-700" %>
            <% else %>
              <%= link_to "Sign in", new_session_path, class: "text-gray-600 hover:text-gray-900" %>
              <%= link_to "Sign up", new_registration_path, class: "bg-ruby-600 text-white px-3 py-1.5 rounded-md hover:bg-ruby-700" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-md px-4 py-3 text-sm">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-5xl mx-auto px-4 mt-4">
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-md px-4 py-3 text-sm">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <footer class="border-t border-gray-200 mt-16 py-8 text-center text-sm text-gray-500">
      <p>RubyCell — Open source Ruby news digest &middot; <a href="https://github.com/yourusername/rubycell" class="hover:text-gray-700">GitHub</a></p>
    </footer>
  </body>
</html>
